<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Game</title>
        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body>
        <nav>
            <div class="nav-container">
                <div class="nav-links">
                    <a href="/">Home</a>
                    <a href="/about">About</a>
                    <a href="/game">Game</a>
                </div>
                <button class="theme-toggle" onclick="toggleTheme()">
                    <span id="theme-icon">🌙</span>
                    <span id="theme-text">Dark</span>
                </button>
            </div>
        </nav>

        <div class="container">
            <h1>The 4×4 Puzzle Game</h1>
            <div style="font-size: 0.9em; color: #666; margin-top: -10px; margin-bottom: 20px; line-height: 1.6;">
                <p style="margin: 5px 0;"><strong>How to Play:</strong> Take turns placing colored shapes on the 4×4 grid. Match 3 or more blocks with the same color OR shape in a row, column, or diagonal to score points and clear them from the board.</p>
                <p style="margin: 5px 0;"><strong>Scoring:</strong> Each matched block = 1 point. Fill all 16 cells to earn a 16-point jackpot bonus!</p>
                <p style="margin: 5px 0;"><strong>Shapes:</strong> Circle ⚪, Square ⬜, Triangle 🔺, Star ⭐ | <strong>Colors:</strong> Red 🔴, Blue 🔵, Yellow 🟡, Green 🟢</p>
            </div>
            <div id="join-area">
                <input id="nameInput" placeholder="Enter your name to join...">
                <button onclick="joinGame()">Join the Game</button>
            </div>
            <button id="quitBtn" onclick="quitGame()">Quit Game</button>

            <h3>Current Turn: <span id="currentTurn"></span></h3>
            <div id="message"></div>

            <div id="game-container">
                <div id="game-main">
                    <div id="currentBlock"></div>
                    <div id="gameGrid"></div>
                </div>
                <div id="scoreboard">
                    <h3>Scoreboard</h3>
                    <table id="score-table">
                        <thead>
                            <tr><th>Player</th><th>Score</th></tr>
                        </thead>
                        <tbody id="score-tbody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <script src="/socket.io/socket.io.js"></script>

        <script>
            const socket = io();
            let myPlayerId = null;
            let myPlayerName = null;
            let currentActiveId = null;
            let clickLocked = false;
            let waitingTimeout = null;
            const WAIT_TIMEOUT = 3000;

            // Theme management
            function getSystemTheme() {
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function applyTheme(theme) {
                if (theme === 'system') {
                    theme = getSystemTheme();
                }
                document.documentElement.setAttribute('data-theme', theme);

                const icon = document.getElementById('theme-icon');
                const text = document.getElementById('theme-text');

                if (theme === 'dark') {
                    icon.textContent = '☀️';
                    text.textContent = 'Light';
                } else {
                    icon.textContent = '🌙';
                    text.textContent = 'Dark';
                }
            }

            function toggleTheme() {
                const currentTheme = localStorage.getItem('theme') || 'system';
                let newTheme;

                if (currentTheme === 'light') {
                    newTheme = 'dark';
                } else if (currentTheme === 'dark') {
                    newTheme = 'system';
                } else {
                    newTheme = 'light';
                }

                localStorage.setItem('theme', newTheme);
                applyTheme(newTheme);

                if (newTheme === 'system') {
                    document.getElementById('theme-text').textContent = 'System';
                }
            }

            const savedTheme = localStorage.getItem('theme') || 'system';
            applyTheme(savedTheme);

            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                if (localStorage.getItem('theme') === 'system') {
                    applyTheme('system');
                }
            });

            // Join / Quit
            function joinGame() {
                const playerName = document.getElementById('nameInput').value.trim();
                if (!playerName) return alert('Please enter a name.');

                // Check if name is already taken before opening window
                socket.emit('checkName', { name: playerName }, (response) => {
                    if (response.available) {
                        // Open a new window for this player
                        const gameWindow = window.open(`/game?name=${encodeURIComponent(playerName)}`, '_blank', 'width=1200,height=800');
                        if (!gameWindow) {
                            alert('Please allow pop-ups for this site to open the game window.');
                        }
                        document.getElementById('nameInput').value = '';
                    } else {
                        alert(response.message);
                    }
                });
            }

            function quitGame() {
                if (!myPlayerId) return alert('You have not joined the game.');
                socket.emit('quitGame', {});
            }

            // Shape rendering
            function createShapeSVG(shape, color) {
                const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
                svg.setAttribute('width', '50');
                svg.setAttribute('height', '50');
                svg.setAttribute('viewBox', '0 0 50 50');

                let el;
                if (shape === 'square') {
                    el = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                    el.setAttribute('x', '10'); el.setAttribute('y', '10');
                    el.setAttribute('width', '30'); el.setAttribute('height', '30');
                } else if (shape === 'circle') {
                    el = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
                    el.setAttribute('cx', '25'); el.setAttribute('cy', '25'); el.setAttribute('r', '15');
                } else if (shape === 'triangle') {
                    el = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
                    el.setAttribute('points', '25,10 40,40 10,40');
                } else if (shape === 'star') {
                    el = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
                    el.setAttribute('points', '25,5 29,18 43,18 32,26 36,40 25,32 14,40 18,26 7,18 21,18');
                }
                if (el) {
                    el.setAttribute('fill', color);
                    svg.appendChild(el);
                }
                return svg;
            }

            // Grid rendering
            function renderGrid(grid) {
                const container = document.getElementById('gameGrid');
                container.innerHTML = '';

                for (let i = 0; i < 16; i++) {
                    const cell = document.createElement('div');
                    cell.className = 'grid-cell';
                    cell.dataset.index = i;

                    if (grid[i]) {
                        cell.appendChild(createShapeSVG(grid[i].shape, grid[i].color));
                    }

                    cell.onclick = () => {
                        if (clickLocked) return;

                        const blockData = document.getElementById('currentBlock').dataset.block;
                        if (!blockData) return;

                        if (!myPlayerId || myPlayerId !== currentActiveId) return;

                        clickLocked = true;

                        socket.emit('placeBlock', { playerId: myPlayerId, index: i });

                        waitingTimeout = setTimeout(() => {
                            alert('Server is not responding. Click OK to retry.');
                            clickLocked = false;
                        }, WAIT_TIMEOUT);
                    };
                    container.appendChild(cell);
                }
            }

            // Scoreboard
            function updateScoreboard(scores) {
                const tbody = document.getElementById('score-tbody');
                const existingRows = {};
                tbody.querySelectorAll('tr').forEach(row => {
                    existingRows[row.dataset.id] = row;
                });

                for (let id in scores) {
                    if (existingRows[id]) {
                        existingRows[id].querySelector('.score-cell').innerText = scores[id].score;
                        existingRows[id].classList.toggle('current-player', id === currentActiveId);
                    } else {
                        const row = document.createElement('tr');
                        row.dataset.id = id;
                        if (id === currentActiveId) row.classList.add('current-player');
                        row.innerHTML = `<td>${scores[id].name}</td><td class="score-cell">${scores[id].score}</td>`;
                        tbody.appendChild(row);
                    }
                }

                for (let id in existingRows) {
                    if (!scores[id]) existingRows[id].remove();
                }
            }

            // Socket events
            socket.on('joinSuccess', (data) => {
                myPlayerId = data.playerId;
                myPlayerName = data.playerName;
                document.getElementById('quitBtn').classList.add('visible');
                document.getElementById('message').innerText = `Welcome, ${data.playerName}!`;
            });

            socket.on('joinError', (data) => {
                console.log('Join error received:', data);
                alert(data.message);

                // If this is a popup window (has name in URL), close it after showing error
                const urlParams = new URLSearchParams(window.location.search);
                if (urlParams.get('name')) {
                    window.close();
                }
            });

            socket.on('placementError', (data) => {
                alert(data.message);
                clickLocked = false;
                if (waitingTimeout) {
                    clearTimeout(waitingTimeout);
                    waitingTimeout = null;
                }
            });

            socket.on('gridUpdate', (grid) => renderGrid(grid));

            socket.on('gameStarted', () => {
                // game is always live
            });

            socket.on('newTurn', (data) => {
                const turnDisplay = document.getElementById('currentTurn');
                const blockDisplay = document.getElementById('currentBlock');
                currentActiveId = data.activePlayerId;

                document.querySelectorAll('#score-tbody tr').forEach(row => {
                    row.classList.toggle('current-player', row.dataset.id === currentActiveId);
                });

                if (data.isYourTurn) {
                    turnDisplay.innerText = `It's your turn, ${data.activePlayerName}`;
                    turnDisplay.classList.add('your-turn');

                    blockDisplay.dataset.block = JSON.stringify(data.block);
                    blockDisplay.innerHTML = '<p>Place this:</p>';

                    const preview = document.createElement('div');
                    preview.className = 'grid-cell';
                    preview.appendChild(createShapeSVG(data.block.shape, data.block.color));
                    blockDisplay.appendChild(preview);
                } else {
                    turnDisplay.innerText = `${data.activePlayerName}'s Turn`;
                    turnDisplay.classList.remove('your-turn');
                    blockDisplay.innerHTML = '';
                    blockDisplay.dataset.block = '';
                }

                if(waitingTimeout){
                    clearTimeout(waitingTimeout);
                    waitingTimeout = null;
                }

                clickLocked = false;
            });

            socket.on('message', (msg) => {
                document.getElementById('message').innerText = msg;
            });

            socket.on('matchSuccess', (data) => {
                // Highlight matched cells
                const cellClass = data.isJackpot ? 'jackpot' : 'matched';
                data.matchedCells.forEach(index => {
                    const cell = document.querySelector(`.grid-cell[data-index="${index}"]`);
                    if (cell) {
                        cell.classList.add(cellClass);
                        setTimeout(() => cell.classList.remove(cellClass), 600);
                    }
                });

                // Show score popup
                const popup = document.createElement('div');
                popup.className = `score-popup${data.isJackpot ? ' jackpot' : ''}`;
                popup.textContent = data.isJackpot
                    ? `🎉 JACKPOT! +${data.pointsEarned} 🎉`
                    : `+${data.pointsEarned}`;
                document.body.appendChild(popup);
                setTimeout(() => popup.remove(), 1500);

                // Highlight scoring player in scoreboard
                const scoringRow = document.querySelector(`#score-tbody tr[data-id="${data.playerId}"]`);
                if (scoringRow) {
                    scoringRow.classList.add('scoring');
                    setTimeout(() => scoringRow.classList.remove('scoring'), 800);
                }
            });

            socket.on('scoreUpdate', (scores) => {
                updateScoreboard(scores);
                document.querySelectorAll('#score-tbody tr').forEach(row => {
                    row.classList.toggle('current-player', row.dataset.id === currentActiveId);
                });

                // If no players left at all, clear the game
                if (Object.keys(scores).length === 0) {
                    document.getElementById('currentTurn').innerText = '';
                    document.getElementById('currentBlock').innerHTML = '';
                    document.getElementById('currentBlock').dataset.block = '';
                    document.getElementById('message').innerText = 'No players in game. Join to start!';
                    renderGrid(Array(16).fill(null));
                }
            });

            socket.on('playLists', (playersList) => {
                const tbody = document.getElementById('score-tbody');
                const existingIds = new Set(playersList.map(p => p.id));

                tbody.querySelectorAll('tr').forEach(row => {
                    if (!existingIds.has(row.dataset.id)) row.remove();
                });

                const existingRows = new Set([...tbody.querySelectorAll('tr')].map(r => r.dataset.id));
                playersList.forEach(player => {
                    if (!existingRows.has(player.id)) {
                        const row = document.createElement('tr');
                        row.dataset.id = player.id;
                        if (player.id === currentActiveId) row.classList.add('current-player');
                        row.innerHTML = `<td>${player.name}</td><td class="score-cell">0</td>`;
                        tbody.appendChild(row);
                    }
                });

                // If no players left at all, clear the game
                if (playersList.length === 0) {
                    document.getElementById('currentTurn').innerText = '';
                    document.getElementById('currentBlock').innerHTML = '';
                    document.getElementById('currentBlock').dataset.block = '';
                    document.getElementById('message').innerText = 'No players in game. Join to start!';
                    renderGrid(Array(16).fill(null));
                }
            });

            socket.on('playerQuit', (data) => {
                if (data.playerId === myPlayerId) {
                    myPlayerId = null;
                    myPlayerName = null;
                    document.getElementById('quitBtn').classList.remove('visible');
                    document.getElementById('currentTurn').innerText = '';
                    document.getElementById('currentBlock').innerHTML = '';
                    document.getElementById('currentBlock').dataset.block = '';
                    document.getElementById('message').innerText = 'You have left the game. Join to play again!';

                    // Clear the grid
                    renderGrid(Array(16).fill(null));

                    // Clear scoreboard
                    document.getElementById('score-tbody').innerHTML = '';
                } else {
                    // Another player quit, show message
                    document.getElementById('message').innerText = data.message || 'A player has left the game.';
                }
            });

            // Auto-join if name is in URL
            window.onload = () => {
                renderGrid(Array(16).fill(null));

                const urlParams = new URLSearchParams(window.location.search);
                const playerName = urlParams.get('name');

                if (playerName) {
                    // This is a game window, hide navigation links
                    document.querySelector('.nav-links').style.display = 'none';
                    document.getElementById('join-area').style.display = 'none';
                }
            };

            // Auto-join when socket connects (for popup windows with name in URL)
            socket.on('connect', () => {
                const urlParams = new URLSearchParams(window.location.search);
                const playerName = urlParams.get('name');

                if (playerName) {
                    // Wait a bit to ensure connection is stable, then join
                    setTimeout(() => {
                        socket.emit('join', { name: playerName });
                    }, 100);
                }
            });

            // Socket disconnect will automatically handle player removal on server side
            // No need for beforeunload/visibilitychange as server's disconnect event handles it
        </script>
    </body>
</html>
