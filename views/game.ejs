<!DOCTYPE html>
<html>
    <head>
        <title>Game</title>
        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body>
        <nav>
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/game">Game</a>
        </nav>

        <h1>The 4*4 Puzzle Game</h1>
        <input id="nameInput" placeholder="Please enter your name.">
        <button onclick="joinGame()">Join the Game</button>
        <button id="startBtn" onclick="startGame()" style="display:none;">Start Game</button>

        <h3>Current Turn: <span id="currentTurn"></span></h3>
        <div id="message"></div>

        <div id="game-container">
            <div id="game-main">
                <div id="gameGrid"></div>
                <div id="currentBlock"></div>
            </div>
            <div id="scoreboard">
                <h3>Scoreboard</h3>
                <table id="score-table">
                    <thead>
                        <tr><th>Player</th><th>Score</th></tr>
                    </thead>
                    <tbody id="score-tbody"></tbody>
                </table>
            </div>
        </div>

        <script src="/socket.io/socket.io.js"></script>

        <script>
            const socket = io();
            let playerName = "";
            let hasJoined = false;
            let gameStarted = false;
            let currentActiveId = null;

            function joinGame(){
                playerName = document.getElementById('nameInput').value.trim();
                if(!playerName) return alert('Please enter a name');
                socket.emit('join', { name: playerName});
                hasJoined = true;
                document.getElementById('nameInput').value = '';
                document.getElementById('message').innerText = `Welcome, ${playerName}!`;
            }

            function startGame(){
                socket.emit('startGame');
                document.getElementById('startBtn').style.display = 'none';
            }

            function renderGrid(grid){
                const container = document.getElementById('gameGrid');
                container.innerHTML = '';

                for (let i = 0; i < 16; i++){
                    const cell = document.createElement('div');
                    cell.className = 'grid-cell';
                    cell.dataset.index = i;

                    if (grid[i]){
                        cell.style.backgroundColor = grid[i].color;
                        cell.innerText = grid[i].shape[0];
                    }

                    cell.onclick = () => {
                        const blockStr = document.getElementById('currentBlock').dataset.block;
                        if (!blockStr) return;
                        socket.emit('placeBlock', {
                            index: i,
                            block: JSON.parse(blockStr)
                        });
                        document.getElementById('currentBlock').innerHTML = '';
                        document.getElementById('currentBlock').dataset.block = '';
                    }
                    container.appendChild(cell);
                }
            }

            function updateScoreboard(scores) {
                const tbody = document.getElementById('score-tbody');
                // 保留现有行顺序，只更新分数；新玩家追加到末尾
                const existingRows = {};
                tbody.querySelectorAll('tr').forEach(row => {
                    existingRows[row.dataset.id] = row;
                });

                for (let id in scores) {
                    if (existingRows[id]) {
                        // 更新分数
                        existingRows[id].querySelector('.score-cell').innerText = scores[id].score;
                        existingRows[id].classList.toggle('current-player', id === currentActiveId);
                    } else {
                        // 新玩家，追加到末尾
                        const row = document.createElement('tr');
                        row.dataset.id = id;
                        if (id === currentActiveId) row.classList.add('current-player');
                        row.innerHTML = `<td>${scores[id].name}</td><td class="score-cell">${scores[id].score}</td>`;
                        tbody.appendChild(row);
                    }
                }

                // 移除已离开的玩家
                for (let id in existingRows) {
                    if (!scores[id]) existingRows[id].remove();
                }
            }

            socket.on('gridUpdate', (grid) => renderGrid(grid));

            socket.on('newTurn', (data) => {
                const turnDisplay = document.getElementById('currentTurn');
                const blockDisplay = document.getElementById('currentBlock');
                currentActiveId = data.activePlayerId;

                // 更新得分表中的当前玩家高亮
                document.querySelectorAll('#score-tbody tr').forEach(row => {
                    row.classList.toggle('current-player', row.dataset.id === currentActiveId);
                });

                if (data.activePlayerId === socket.id) {
                    turnDisplay.innerText = `It's your turn, ${data.activePlayerName}`;
                    turnDisplay.style.color = "red";

                    blockDisplay.dataset.block = JSON.stringify(data.block);
                    blockDisplay.innerHTML = `<p>Place this:</p>`;

                    const preview = document.createElement('div');
                    preview.className = 'grid-cell';
                    preview.style.backgroundColor = data.block.color;
                    preview.innerText = data.block.shape[0];
                    blockDisplay.appendChild(preview);
                } else {
                    turnDisplay.innerText = `${data.activePlayerName}'s Turn`;
                    turnDisplay.style.color = "black";
                    blockDisplay.innerText = `Waiting for ${data.activePlayerName}...`;
                    blockDisplay.dataset.block = "";
                }
            });

            socket.on('message', (msg) => {
                document.getElementById('message').innerText = msg;
            });

            socket.on('scoreUpdate', (scores) => {
                updateScoreboard(scores);
                // 更新后重新应用当前玩家高亮
                document.querySelectorAll('#score-tbody tr').forEach(row => {
                    row.classList.toggle('current-player', row.dataset.id === currentActiveId);
                });
            });

            socket.on('playLists', (playersList) => {
                // 游戏开始前,完全重建玩家列表
                if (!gameStarted) {
                    const tbody = document.getElementById('score-tbody');
                    tbody.innerHTML = '';
                    playersList.forEach(player => {
                        const row = document.createElement('tr');
                        row.dataset.id = player.id;
                        row.innerHTML = `<td>${player.name}</td><td class="score-cell">0</td>`;
                        tbody.appendChild(row);
                    });
                }
                if (hasJoined && playersList.length >= 1) {
                    document.getElementById('startBtn').style.display = 'inline-block';
                }
            });

            socket.on('gameStarted', () => {
                gameStarted = true;
                document.getElementById('message').innerText = 'Game Started!';
                document.getElementById('startBtn').style.display = 'none';
            });

            window.onload = () => renderGrid(Array(16).fill(null));
        </script>
    </body>
</html>
